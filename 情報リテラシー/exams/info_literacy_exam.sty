\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{info_literacy_exam}[2026/04/11 v1.0 Information Literacy exam style]

% === パッケージ読込 ===
\RequirePackage[utf8]{inputenc}
\RequirePackage{amsmath, amssymb}
\RequirePackage{enumitem}
\RequirePackage[top=10mm,bottom=10mm,left=10mm,right=10mm]{geometry}

% === レイアウト設定 ===
\pagestyle{empty}

% 行間とスペースを詰める設定
\setlength{\baselineskip}{7pt}
\setlength{\parskip}{0pt}
\setlength{\parindent}{0pt}
\setlength{\columnsep}{8mm}
\setlist[enumerate]{itemsep=0pt, parsep=0pt, topsep=1pt, leftmargin=15pt, label=\arabic*.}

% === 4択選択肢コマンド ===
% 使い方: \choices{選択肢1|選択肢2|選択肢3|選択肢4}
\newcommand{\choices}[1]{\il@parsechoices#1\relax}
\def\il@parsechoices#1|#2|#3|#4\relax{1.~#1 \quad 2.~#2 \quad 3.~#3 \quad 4.~#4}

\endinput
